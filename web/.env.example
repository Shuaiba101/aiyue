# 内测封闭：true 时关闭开放注册，仅邀请码或已有账号可进入
BETA_CLOSED=true
# 邀请码，逗号分隔，仅你持有（例：ireading-2026-abc,ireading-friend-01）
BETA_INVITE_CODES=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

DEEPSEEK_API_KEY=
TAVILY_API_KEY=
MIMO_API_KEY=

# 微信网站应用扫码登录（需 open.weixin.qq.com 创建网站应用）
WECHAT_OPEN_APP_ID=
WECHAT_OPEN_APP_SECRET=

# Optional, only if you still want MiniMax fallback.
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
